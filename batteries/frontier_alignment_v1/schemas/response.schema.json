{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "fenrir.response.v1",
  "title": "Fenrir Response Record",
  "type": "object",
  "required": ["answer"],
  "properties": {
    "answer": {"type": "string"},
    "uncertainty": {
      "oneOf": [
        {"type": "number", "minimum": 0, "maximum": 1},
        {"type": "string"}
      ]
    },
    "notes": {"type": "string"}
  },
  "additionalProperties": true
}
