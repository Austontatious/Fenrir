{
  "$defs": {
    "ConditionProvenance": {
      "additionalProperties": false,
      "properties": {
        "condition_id": {
          "title": "Condition Id",
          "type": "string"
        },
        "condition_version": {
          "title": "Condition Version",
          "type": "string"
        },
        "inline_prompt_hash": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Inline Prompt Hash"
        },
        "production_wrapper_source": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Production Wrapper Source"
        },
        "prompt_template_version": {
          "title": "Prompt Template Version",
          "type": "string"
        },
        "stress_profile_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Stress Profile Id"
        },
        "stress_profile_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Stress Profile Version"
        },
        "system_prompt_hash": {
          "title": "System Prompt Hash",
          "type": "string"
        },
        "system_prompt_source": {
          "title": "System Prompt Source",
          "type": "string"
        }
      },
      "required": [
        "condition_id",
        "condition_version",
        "system_prompt_source",
        "system_prompt_hash",
        "prompt_template_version"
      ],
      "title": "ConditionProvenance",
      "type": "object"
    },
    "WrapperDependenceReport": {
      "additionalProperties": false,
      "properties": {
        "bucket": {
          "enum": [
            "low",
            "moderate",
            "high"
          ],
          "title": "Bucket",
          "type": "string"
        },
        "explanation": {
          "title": "Explanation",
          "type": "string"
        },
        "index": {
          "title": "Index",
          "type": "number"
        },
        "pair_deltas": {
          "additionalProperties": {
            "type": "number"
          },
          "title": "Pair Deltas",
          "type": "object"
        }
      },
      "required": [
        "index",
        "bucket",
        "explanation"
      ],
      "title": "WrapperDependenceReport",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "caveats": {
      "items": {
        "type": "string"
      },
      "title": "Caveats",
      "type": "array"
    },
    "condition_provenance": {
      "$ref": "#/$defs/ConditionProvenance"
    },
    "contradictions": {
      "items": {
        "type": "string"
      },
      "title": "Contradictions",
      "type": "array"
    },
    "coverage": {
      "additionalProperties": true,
      "title": "Coverage",
      "type": "object"
    },
    "prohibited_inferences": {
      "items": {
        "type": "string"
      },
      "title": "Prohibited Inferences",
      "type": "array"
    },
    "report_version": {
      "default": "1.0.0",
      "title": "Report Version",
      "type": "string"
    },
    "risk_flags": {
      "additionalProperties": {
        "type": "integer"
      },
      "title": "Risk Flags",
      "type": "object"
    },
    "run_id": {
      "title": "Run Id",
      "type": "string"
    },
    "schema_version": {
      "const": "fenrir.report.v1",
      "default": "fenrir.report.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "stability_metrics": {
      "additionalProperties": {
        "type": "number"
      },
      "title": "Stability Metrics",
      "type": "object"
    },
    "summary": {
      "title": "Summary",
      "type": "string"
    },
    "trait_scores": {
      "additionalProperties": {
        "type": "number"
      },
      "title": "Trait Scores",
      "type": "object"
    },
    "wrapper_dependence": {
      "$ref": "#/$defs/WrapperDependenceReport"
    }
  },
  "required": [
    "run_id",
    "summary",
    "trait_scores",
    "risk_flags",
    "stability_metrics",
    "wrapper_dependence",
    "contradictions",
    "coverage",
    "condition_provenance",
    "caveats",
    "prohibited_inferences"
  ],
  "title": "ReportRecord",
  "type": "object"
}
