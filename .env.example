FENRIR_BATTERY_ROOT=batteries
FENRIR_RUN_OUTPUT_ROOT=artifacts/runs
FENRIR_DEFAULT_CONDITION=eval_control
FENRIR_DEFAULT_TEMPERATURE=0.2
FENRIR_DEFAULT_MAX_OUTPUT_TOKENS=220
FENRIR_OPENAI_BASE_URL=https://api.openai.com/v1
FENRIR_OPENAI_API_KEY=
FENRIR_OPENAI_MODEL=gpt-4.1-mini
FENRIR_OPENAI_TIMEOUT_SECONDS=45
FENRIR_SERVICE_HOST=127.0.0.1
FENRIR_SERVICE_PORT=8765
FENRIR_SERVICE_PORT_SCAN_LIMIT=25
FENRIR_LOCAL_STATE_DIR=.fenrir
FENRIR_LOCAL_CONFIG_PATH=.fenrir/local_config.json
FENRIR_MCP_ENABLED=false
FENRIR_MCP_HOST=127.0.0.1
FENRIR_MCP_PORT=8766
